    "frontend:dev": "cd frontend && npm run dev",
    "demo": "echo Run in order: 1) npm run node  2) npm run deploy:local  3) npm run frontend:dev"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^17.3.1",
    "hardhat": "^2.22.10"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
